<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Suggestion Box</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <h1><%= article.title %></h1>
    <p class="subtitle"><strong>Posted by </strong> <%= article.author %></p>

    <% if (showPasswordForm) { %>
      <div class="form-card">
        <% if (error) { %><div class="error"><%= error %></div><% } %>
        <p style="text-align:center;">This article is private. Please enter the password to view it.</p>
        <form method="post" action="/article/<%= article.id %>">
          <div class="form-row">
            <label>Password</label>
            <input type="password" name="password" required>
          </div>
          <div class="form-row" style="text-align:center;">
            <button class="btn" type="submit">Submit</button>
          </div>
        </form>
      </div>
    <% } else { %>
      <div class="form-card">
        <div style="line-height:1.6; color:#222;">
          <%- article.contentHtml %>
        </div>
      </div>
    <% } %>

    <div class="actions" style="margin-top:18px;">
      <a class="link-muted" href="/">Back to list</a>
    </div>
  </div>
</body>
</html>
